# Twilio console -> Account -> API keys & tokens
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio number your dashboard tracks (buy/use from Twilio console)
TWILIO_PHONE_NUMBER=+91xxxxxxxxxx

# Your Twilio WhatsApp sender (sandbox number is +14155238886 for testing,
# or your approved WhatsApp Business number for production)
TWILIO_WHATSAPP_NUMBER=+14155238886

# Where notifications should land — your personal phone number
NOTIFY_PHONE_NUMBER=+91xxxxxxxxxx
NOTIFY_WHATSAPP_NUMBER=+91xxxxxxxxxx

# Password to view the dashboard (browser will prompt for username+password,
# username can be anything, only the password is checked)
DASHBOARD_PASSWORD=choose_a_strong_password
